<?xml version="1.0" encoding="UTF-8"?>
<model name="ai:dockiaagentsmodel" xmlns="http://www.alfresco.org/model/dictionary/1.0">

  <description>Modelo de contenido para registrar agentes de IA gestionados desde Alfresco.</description>
  <author>cparedesr</author>
  <version>1.2</version>

  <imports>
    <import uri="http://www.alfresco.org/model/dictionary/1.0" prefix="d"/>
    <import uri="http://www.alfresco.org/model/content/1.0" prefix="cm"/>
  </imports>

  <namespaces>
    <namespace uri="http://www.cparedesr.com/model/aiagents/1.0" prefix="ai"/>
    <namespace uri="http://www.cparedesr.com/model/extractmetadata/1.0" prefix="em"/>
  </namespaces>

  <types>
    <type name="ai:agent">
      <title>AI Agent</title>
      <parent>cm:content</parent>

      <properties>
        <property name="ai:agentId">
          <type>d:text</type>
          <mandatory>true</mandatory>
          <index enabled="true">
            <atomic>true</atomic>
            <stored>true</stored>
            <tokenised>false</tokenised>
          </index>
        </property>

        <property name="ai:name">
          <type>d:text</type>
          <mandatory>true</mandatory>
          <index enabled="true">
            <atomic>true</atomic>
            <stored>true</stored>
            <tokenised>false</tokenised>
          </index>
        </property>

        <property name="ai:image">
          <type>d:text</type>
          <mandatory>true</mandatory>
        </property>

        <property name="ai:documentType">
          <type>d:text</type>
          <mandatory>true</mandatory>
        </property>

        <property name="ai:desiredState">
          <type>d:text</type>
          <mandatory>true</mandatory>
        </property>

        <property name="ai:currentState">
          <type>d:text</type>
          <mandatory>true</mandatory>
        </property>

        <property name="ai:health">
          <type>d:text</type>
          <mandatory>false</mandatory>
        </property>

        <property name="ai:containerId">
          <type>d:text</type>
          <mandatory>false</mandatory>
        </property>

        <property name="ai:configJson">
          <type>d:text</type>
          <mandatory>true</mandatory>
        </property>

        <property name="ai:createdAt">
          <type>d:datetime</type>
          <mandatory>true</mandatory>
        </property>

        <property name="ai:updatedAt">
          <type>d:datetime</type>
          <mandatory>true</mandatory>
        </property>
      </properties>
    </type>
  </types>

  <aspects>
    <aspect name="em:personMetadata">
      <title>Metadatos personales extraidos</title>
      <properties>
        <property name="em:nombre">
          <title>Nombre</title>
          <type>d:text</type>
          <mandatory>false</mandatory>
        </property>

        <property name="em:apellido1">
          <title>Apellido 1</title>
          <type>d:text</type>
          <mandatory>false</mandatory>
        </property>

        <property name="em:apellido2">
          <title>Apellido 2</title>
          <type>d:text</type>
          <mandatory>false</mandatory>
        </property>

        <property name="em:dni">
          <title>DNI</title>
          <type>d:text</type>
          <mandatory>false</mandatory>
          <index enabled="true">
            <atomic>true</atomic>
            <stored>true</stored>
            <tokenised>false</tokenised>
          </index>
        </property>

        <property name="em:fechaNacimiento">
          <title>Fecha de nacimiento</title>
          <type>d:date</type>
          <mandatory>false</mandatory>
        </property>
      </properties>
    </aspect>
  </aspects>

</model>
