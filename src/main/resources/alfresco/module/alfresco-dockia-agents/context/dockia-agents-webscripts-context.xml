<?xml version='1.0' encoding='UTF-8'?>
<!--

  Contexto Spring de los Web Scripts. Los servicios operativos viven dentro
  del subsistema DockIA Agents.
-->
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
          http://www.springframework.org/schema/beans
          http://www.springframework.org/schema/beans/spring-beans.xsd">

  <bean id="webscript.com.cparedesr.dockia.agents.agents.post"
        class="com.cparedesr.dockia.agents.webscripts.DeployAgentPostWebScript"
        parent="webscript">
    <property name="subsystemServiceLocator" ref="dockia.agents.subsystemServiceLocator"/>
  </bean>

  <bean id="webscript.com.cparedesr.dockia.agents.agents.get"
        class="com.cparedesr.dockia.agents.webscripts.ListAgentsGetWebScript"
        parent="webscript">
    <property name="subsystemServiceLocator" ref="dockia.agents.subsystemServiceLocator"/>
  </bean>

  <bean id="webscript.com.cparedesr.dockia.agents.agents-id.get"
        class="com.cparedesr.dockia.agents.webscripts.GetAgentByIdWebScript"
        parent="webscript">
    <property name="subsystemServiceLocator" ref="dockia.agents.subsystemServiceLocator"/>
  </bean>

  <bean id="webscript.com.cparedesr.dockia.agents.agents-id.delete"
        class="com.cparedesr.dockia.agents.webscripts.DeleteAgentWebScript"
        parent="webscript">
    <property name="subsystemServiceLocator" ref="dockia.agents.subsystemServiceLocator"/>
  </bean>

</beans>
